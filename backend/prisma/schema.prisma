generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Material {
  id                String            @id
  nombre            String
  unidad            String
  costo             Float
  proveedor         String            @default("")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  consumos          Consumo[]
  optimalMateriales OptimalMaterial[]
}

model Referencia {
  id                String            @id
  nombre            String            @default("")
  familia           String            @default("")
  segMOD            Float             @default(60)
  cifUnitario       Float             @default(0)
  costoReal         Float             @default(0)
  mes               String
  fechaCreacion     String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  consumos          Consumo[]
  optimalMateriales OptimalMaterial[]

  @@index([mes])
}

model Consumo {
  id           Int        @id @default(autoincrement())
  referenciaId String
  materialId   String
  cantidad     Float
  referencia   Referencia @relation(fields: [referenciaId], references: [id], onDelete: Cascade)
  material     Material   @relation(fields: [materialId], references: [id])

  @@unique([referenciaId, materialId])
  @@index([materialId])
}

// Líneas de pesaje manual de materias primas en planta (feature "Costo Óptimo").
// El precio nunca se copia aquí — siempre se resuelve en vivo desde Material.costo
// para que una reimportación del CSV de Odoo actualice el costo óptimo automáticamente.
model OptimalMaterial {
  id           Int        @id @default(autoincrement())
  referenciaId String
  materialId   String
  cantidad     Float
  updatedAt    DateTime   @updatedAt
  referencia   Referencia @relation(fields: [referenciaId], references: [id], onDelete: Cascade)
  material     Material   @relation(fields: [materialId], references: [id])

  @@unique([referenciaId, materialId])
  @@index([materialId])
}

model Parametros {
  id        Int   @id @default(1)
  tarifaMOD Float @default(9500) // DEPRECATED: no interviene en cálculos ni en la exportación — no eliminar para estabilidad del schema
  pctGAV    Float @default(18) // DEPRECATED: gastos adm. y ventas — ya no se usa en la exportación (reporte solo de costos); no eliminar para estabilidad del schema
  pctMargen Float @default(25) // DEPRECATED: margen de utilidad sobre ventas — ya no se usa en la exportación (reporte solo de costos); no eliminar para estabilidad del schema
}

model Usuario {
  id           Int    @id @default(1)
  passwordHash String
}

model CostOrder {
  id                Int            @id @default(autoincrement())
  orden             String         @unique
  documentoOrigen   String
  refDonsson        String
  producto          String
  productoCodigo    String
  productoClase     String
  cantidadFabricada Float
  fechaInicial      DateTime
  fechaFinal        DateTime
  estado            String
  totalPlaneado     Float
  totalEjecutado    Float
  totalVariacion    Float
  fechaImportacion  DateTime       @default(now())
  archivoFuente     String
  laborItems        CostLabor[]
  materials         CostMaterial[]

  @@index([refDonsson])
  @@index([fechaFinal])
}

model CostLabor {
  id                  Int       @id @default(autoincrement())
  orderId             Int
  order               CostOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tipo                String
  proceso             String
  cantStd             Float?
  vrStd               Float?
  tarifaStd           Float?
  cantPlaneado        Float
  vrPlaneado          Float
  tarifaPlaneada      Float?
  cantEjecutado       Float
  vrEjecutado         Float
  tarifaEjecutada     Float?
  variacionCantidad   Float
  variacionValor      Float
  variacionPct        Float
  eficienciaTiempoPct Float?
  alertaTarifa        Boolean   @default(false)

  @@unique([orderId, proceso])
}

model CostMaterial {
  id                Int       @id @default(autoincrement())
  orderId           Int
  order             CostOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  insumo            String
  costoMp           Float
  cantStd           Float?
  vrStd             Float?
  cantPlaneado      Float
  vrPlaneado        Float
  cantEjecutado     Float
  vrEjecutado       Float
  variacionCantidad Float
  variacionValor    Float
  variacionPct      Float
  alertaCantidad    Boolean   @default(false)

  @@unique([orderId, insumo])
}
