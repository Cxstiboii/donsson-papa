generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Material {
  id        String    @id
  nombre    String
  unidad    String
  costo     Float
  proveedor String    @default("")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  consumos  Consumo[]
}

model Referencia {
  id            String    @id
  nombre        String    @default("")
  familia       String    @default("")
  segMOD        Float     @default(60)
  cifUnitario   Float     @default(0)
  costoReal     Float     @default(0)
  mes           String
  fechaCreacion String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  consumos      Consumo[]

  @@index([mes])
}

model Consumo {
  id           Int        @id @default(autoincrement())
  referenciaId String
  materialId   String
  cantidad     Float
  referencia   Referencia @relation(fields: [referenciaId], references: [id], onDelete: Cascade)
  material     Material   @relation(fields: [materialId], references: [id])

  @@unique([referenciaId, materialId])
  @@index([materialId])
}

model Parametros {
  id        Int   @id @default(1)
  tarifaMOD Float @default(9500)
  pctGAV    Float @default(18)
  pctMargen Float @default(25)
}

model Usuario {
  id           Int    @id @default(1)
  passwordHash String
}

model CostOrder {
  id                Int            @id @default(autoincrement())
  orden             String         @unique
  documentoOrigen   String
  refDonsson        String
  producto          String
  productoCodigo    String
  productoClase     String
  cantidadFabricada Float
  fechaInicial      DateTime
  fechaFinal        DateTime
  estado            String
  totalPlaneado     Float
  totalEjecutado    Float
  totalVariacion    Float
  fechaImportacion  DateTime       @default(now())
  archivoFuente     String
  laborItems        CostLabor[]
  materials         CostMaterial[]

  @@index([refDonsson])
  @@index([fechaFinal])
}

model CostLabor {
  id                  Int       @id @default(autoincrement())
  orderId             Int
  order               CostOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tipo                String
  proceso             String
  cantStd             Float?
  vrStd               Float?
  tarifaStd           Float?
  cantPlaneado        Float
  vrPlaneado          Float
  tarifaPlaneada      Float?
  cantEjecutado       Float
  vrEjecutado         Float
  tarifaEjecutada     Float?
  variacionCantidad   Float
  variacionValor      Float
  variacionPct        Float
  eficienciaTiempoPct Float?
  alertaTarifa        Boolean   @default(false)

  @@unique([orderId, proceso])
}

model CostMaterial {
  id                Int       @id @default(autoincrement())
  orderId           Int
  order             CostOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  insumo            String
  costoMp           Float
  cantStd           Float?
  vrStd             Float?
  cantPlaneado      Float
  vrPlaneado        Float
  cantEjecutado     Float
  vrEjecutado       Float
  variacionCantidad Float
  variacionValor    Float
  variacionPct      Float
  alertaCantidad    Boolean   @default(false)

  @@unique([orderId, insumo])
}
